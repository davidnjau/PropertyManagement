# Application
PORT=3001
FRONTEND_URL=http://localhost:8080

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/buildagent_dev
DB_USER=buildagent
DB_PASSWORD=buildagent_dev
DB_MAX_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=buildagent-backend
KAFKA_CLIENT_ID=buildagent-producer

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.buildagent.io
AUTH0_NAMESPACE=https://buildagent.io/

# AWS S3
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=buildagent-documents-dev

# SendGrid
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@buildagent.io
